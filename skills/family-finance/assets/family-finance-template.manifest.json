{
  "schema_version": "1.0.0",
  "template_version": "1.0.0",
  "unit_policy": {
    "default_unit": "wan",
    "default_currency": "CNY",
    "precision": 4
  },
  "annual_sheet_naming": {
    "cashflow": "{year}现金流",
    "balance": "{year}资产负债"
  },
  "sheets": {
    "config": {
      "title": "_config",
      "role": "profile_config"
    },
    "snapshots": {
      "title": "_snapshots",
      "role": "balance_snapshots"
    },
    "imports": {
      "title": "_imports",
      "role": "operation_log"
    },
    "cashflow_template": {
      "title": "_template_cashflow",
      "role": "cashflow_seed",
      "frozen_row_count": 1,
      "frozen_column_count": 1
    },
    "balance_template": {
      "title": "_template_balance",
      "role": "balance_seed",
      "frozen_row_count": 1,
      "frozen_column_count": 0
    }
  },
  "month_rows": {
    "01": 3,
    "02": 4,
    "03": 5,
    "04": 6,
    "05": 7,
    "06": 8,
    "07": 9,
    "08": 10,
    "09": 11,
    "10": 12,
    "11": 13,
    "12": 14
  },
  "field_mappings": {
    "cashflow": {
      "income": {
        "member_a_salary": {
          "column": "B",
          "kind": "number",
          "label": "成员A工资"
        },
        "member_b_salary": {
          "column": "C",
          "kind": "number",
          "label": "成员B工资"
        },
        "housing_fund": {
          "column": "D",
          "kind": "number",
          "label": "公积金"
        },
        "other_income": {
          "column": "E",
          "kind": "number",
          "label": "其他收入",
          "note_field": "income_note"
        },
        "income_note": {
          "column": "F",
          "kind": "note",
          "label": "收入说明"
        }
      },
      "expense": {
        "fixed_expense": {
          "column": "H",
          "kind": "number",
          "label": "固定支出"
        },
        "flexible_expense": {
          "column": "I",
          "kind": "number",
          "label": "弹性支出"
        },
        "special_expense": {
          "column": "J",
          "kind": "number",
          "label": "特殊支出",
          "note_field": "expense_note"
        },
        "expense_note": {
          "column": "K",
          "kind": "note",
          "label": "支出说明"
        }
      },
      "asset_conversion": {
        "recurring_conversion": {
          "column": "M",
          "kind": "number",
          "label": "定期转化"
        },
        "other_conversion": {
          "column": "N",
          "kind": "number",
          "label": "其他转化",
          "note_field": "asset_conversion_note"
        },
        "asset_conversion_note": {
          "column": "O",
          "kind": "note",
          "label": "资产转化说明"
        }
      },
      "asset_change": {
        "equity_units": {
          "column": "V",
          "kind": "number",
          "label": "公司股权/RSU数量",
          "precision": 4
        },
        "equity_amount": {
          "column": "W",
          "kind": "formula",
          "label": "公司股权/RSU金额"
        },
        "asset_income": {
          "column": "X",
          "kind": "number",
          "label": "资产收入",
          "note_field": "asset_change_note"
        },
        "asset_loss": {
          "column": "Y",
          "kind": "number",
          "label": "资产减损",
          "note_field": "asset_change_note"
        },
        "asset_change_note": {
          "column": "Z",
          "kind": "note",
          "label": "资产收支说明"
        }
      }
    }
  },
  "writable_ranges": {
    "cashflow": [
      "B3:F14",
      "H3:K14",
      "M3:O14",
      "V3:Z14",
      "T2",
      "W2"
